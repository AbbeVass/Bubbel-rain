{
  "manifest_version": 3,
  "name": "Bubbel rain",
  "version": "1.1",
  "description": "Creates a constant rain of Bubbel or your own desired image.",
  "icons": {
    "64": "img/icon-64.png",
    "105": "img/icon-105.png",
    "420": "img/icon-420.png"
  },
  "action": {
    "default_popup": "src/control.html"
  },
  "content_scripts": [
    {
        "matches": ["<all_urls>"],
        "js": ["src/content.js"]
    }
  ],
  "permissions": [
    "storage"
  ]
}
